<mxfile host="app.diagrams.net" modified="2026-04-13T08:55:00Z" agent="Codex" version="26.0.11" type="device" compressed="false">
  <diagram id="robotsrun-how-it-works" name="RobotsRun How It Works">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="RobotsRun 是怎么工作的&#xa;首页先看产品主线，不先看内部模块图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=26;fontStyle=1;arcSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="1520" height="92" as="geometry" />
        </mxCell>
        <mxCell id="10" value="1. 用户对设备说一句话&#xa;&#xa;设备负责听、播、打断&#xa;用户不用理解后台结构" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#60a5fa;fontColor=#1e3a8a;fontSize=22;fontStyle=1;arcSize=22;" vertex="1" parent="1">
          <mxGeometry x="70" y="210" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="11" value="2. 你在后台选好要接的能力&#xa;&#xa;管理台里配 Channel、绑定 Agent&#xa;也能直接做调试和排障" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#22c55e;fontColor=#166534;fontSize=22;fontStyle=1;arcSize=22;" vertex="1" parent="1">
          <mxGeometry x="450" y="210" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="12" value="3. OpenClaw 智能体开始处理任务&#xa;&#xa;理解请求、调用工具、协作生成结果&#xa;这里才是内部智能体运行层" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#a78bfa;fontColor=#6d28d9;fontSize=22;fontStyle=1;arcSize=22;" vertex="1" parent="1">
          <mxGeometry x="830" y="210" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="13" value="4. 结果分两路回来&#xa;&#xa;短结果：设备语音简报&#xa;长结果：IM 详细稿 / 群消息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#9a3412;fontSize=22;fontStyle=1;arcSize=22;" vertex="1" parent="1">
          <mxGeometry x="1210" y="210" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="20" value="用户能感知到的，就是这 4 步。&#xa;内部是多仓协作，但对外可以讲成一条简单产品链路。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;fontColor=#334155;fontSize=21;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="280" y="470" width="1040" height="90" as="geometry" />
        </mxCell>
        <mxCell id="30" value="维护者日常更新方式&#xa;改对应子仓 -&gt; commit / push -&gt; GitHub Actions 自动发布 -&gt; 线上环境更新" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontColor=#92400e;fontSize=22;fontStyle=1;arcSize=22;" vertex="1" parent="1">
          <mxGeometry x="250" y="640" width="1100" height="100" as="geometry" />
        </mxCell>
        <mxCell id="40" value="用户视角主线" style="ellipse;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;fontColor=#ffffff;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="150" width="240" height="44" as="geometry" />
        </mxCell>
        <mxCell id="50" value="说话" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#60a5fa;fontColor=#1e3a8a;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="166" y="162" width="108" height="38" as="geometry" />
        </mxCell>
        <mxCell id="51" value="配置" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontColor=#166534;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="548" y="162" width="108" height="38" as="geometry" />
        </mxCell>
        <mxCell id="52" value="处理" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#a78bfa;fontColor=#6d28d9;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="928" y="162" width="108" height="38" as="geometry" />
        </mxCell>
        <mxCell id="53" value="返回" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#fb923c;fontColor=#9a3412;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1308" y="162" width="108" height="38" as="geometry" />
        </mxCell>
        <mxCell id="60" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="10" target="11">
          <mxGeometry relative="1" as="geometry" />
